\@writefile{lof}{\contentsline {figure}{\numberline {9.1}{\ignorespaces Projection / collapse under the feature map $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}$. Three configurations $X_1, X_2$, and $G(y)$ (the canonical representative) map to the same observable value $y$ (all lie on the horizontal line $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}(X) = y$). The arrows show how the configuration-space vertical direction is collapsed to a single point in $\mathcal  {Y}$. Distances along the $\ker (\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F})$-direction (horizontal bracket) are annihilated by the projection, constituting the reconstruction defect.}}{29}{figure.9.1}\protected@file@percent }
\newlabel{fig:projection-collapse}{{9.1}{29}{Projection / collapse under the feature map $\Ft $. Three configurations $X_1, X_2$, and $G(y)$ (the canonical representative) map to the same observable value $y$ (all lie on the horizontal line $\Ft (X) = y$). The arrows show how the configuration-space vertical direction is collapsed to a single point in $\mathcal {Y}$. Distances along the $\ker (\Ft )$-direction (horizontal bracket) are annihilated by the projection, constituting the reconstruction defect}{figure.9.1}{}}
\newlabel{fig:projection-collapse@cref}{{[figure][1][9]9.1}{[1][28][]29}}
\@writefile{toc}{\contentsline {section}{\numberline {9.4}Reconstruction as a section of the quotient projection}{29}{section.9.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9.2}{\ignorespaces \textbf  {Left:} The observational quotient: $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}$ factors through the quotient projection $\pi $ and the isomorphism $\bar  \setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}$. Distinct configurations in the same fiber of $\pi $ are observationally indistinguishable. \textbf  {Right:} The section property $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}\circ G = \mathrm  {id}_{\mathcal  {Y}}$: reconstruction selects a canonical lift from each observation back to configuration space. Together, these diagrams encode the full geometry of projection loss.}}{29}{figure.9.2}\protected@file@percent }
\newlabel{fig:quotient-section}{{9.2}{29}{\textbf {Left:} The observational quotient: $\Ft $ factors through the quotient projection $\pi $ and the isomorphism $\bar \Ft $. Distinct configurations in the same fiber of $\pi $ are observationally indistinguishable. \textbf {Right:} The section property $\Ft \circ G = \mathrm {id}_{\mathcal {Y}}$: reconstruction selects a canonical lift from each observation back to configuration space. Together, these diagrams encode the full geometry of projection loss}{figure.9.2}{}}
\newlabel{fig:quotient-section@cref}{{[figure][2][9]9.2}{[1][29][]29}}
