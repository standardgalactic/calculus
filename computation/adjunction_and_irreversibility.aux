\@writefile{lof}{\contentsline {figure}{\numberline {9.4}{\ignorespaces Non-injectivity of the feature map $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}$: the distinct configurations $X_1$ and $X_2$ (blue dots) share the same feature value $y$, lying in the same fiber $\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F}^{-1}(y)$ (dashed horizontal segment). The reconstruction $G(y)$ selects a single canonical representative from this fiber (red diamond), necessarily discarding the direction $X_1 - X_2 \in \ker (\setbox \z@ \hbox {\mathsurround \z@ $\textstyle F$}\mathaccent "0365{F})$. By \cref  {thm:no-go}, such fibers are infinite-dimensional for any finite feature map.}}{31}{figure.9.4}\protected@file@percent }
\newlabel{fig:non-injectivity}{{9.4}{31}{Non-injectivity of the feature map $\Ft $: the distinct configurations $X_1$ and $X_2$ (blue dots) share the same feature value $y$, lying in the same fiber $\Ft ^{-1}(y)$ (dashed horizontal segment). The reconstruction $G(y)$ selects a single canonical representative from this fiber (red diamond), necessarily discarding the direction $X_1 - X_2 \in \ker (\Ft )$. By \cref {thm:no-go}, such fibers are infinite-dimensional for any finite feature map}{figure.9.4}{}}
\newlabel{fig:non-injectivity@cref}{{[figure][4][9]9.4}{[1][31][]31}}
