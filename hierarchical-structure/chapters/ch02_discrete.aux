\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces \textit  {Left}: A rooted binary tree on four leaves. Internal nodes are labeled with their lowest common ancestors. \textit  {Right}: The corresponding laminar family of leaf sets. Each internal node of the tree corresponds to a set in the laminar family, and containment of sets mirrors the ancestor relation.}}{10}{figure.2.1}\protected@file@percent }
\newlabel{fig:tree_and_laminar}{{2.1}{10}{\textit {Left}: A rooted binary tree on four leaves. Internal nodes are labeled with their lowest common ancestors. \textit {Right}: The corresponding laminar family of leaf sets. Each internal node of the tree corresponds to a set in the laminar family, and containment of sets mirrors the ancestor relation}{figure.2.1}{}}
