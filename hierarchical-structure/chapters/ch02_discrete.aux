\@writefile{lof}{\contentsline {figure}{\numberline {2.2}{\ignorespaces All distinct rooted binary tree topologies for $n=3$ (left) and $n=4$ (right), illustrating the combinatorial explosion $|\mathcal  {T}_n| = (2n-3)!!$. For $n=5$ there are already 15 topologies, and for $n=10$ there are 945. This superexponential growth defines the difficulty of the inference problem.}}{11}{figure.2.2}\protected@file@percent }
\newlabel{fig:tree_count}{{2.2}{11}{All distinct rooted binary tree topologies for $n=3$ (left) and $n=4$ (right), illustrating the combinatorial explosion $|\mathcal {T}_n| = (2n-3)!!$. For $n=5$ there are already 15 topologies, and for $n=10$ there are 945. This superexponential growth defines the difficulty of the inference problem}{figure.2.2}{}}
